# Required for AI previews
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Sports APIs
NBA_API_KEY=your_balldontlie_key         # balldontlie.io — free tier
WC_API_KEY=                              # not needed, uses FOOTBALL_DATA_API_KEY

# Soccer APIs (pick one or both for best coverage)
FOOTBALL_DATA_API_KEY=your_fd_key        # football-data.org — free, covers UCL/EPL/LL/BL/SA/L1/EC/WC
API_FOOTBALL_KEY=your_apif_key           # api-sports.io — freemium, covers 60+ competitions

# NHL and MLB use official free APIs — no keys needed
